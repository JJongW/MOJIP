# Supabase (Vercel 배포 시 환경 변수로 설정)
# https://supabase.com/dashboard 프로젝트 설정 > API에서 확인
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# 카카오톡 공유 (선택) - 설정 시 카카오 공유 창, 미설정 시 링크 복사
# https://developers.kakao.com 콘솔 > 앱 > 앱 키 > JavaScript 키
VITE_KAKAO_JAVASCRIPT_KEY=

# 카카오톡 공유 사용자 정의 템플릿 (선택) - 설정 시 sendCustom 사용, 미설정 시 기본 피드 템플릿
# [도구] > [메시지 템플릿]에서 모집글 공유용 템플릿 생성 후 발급된 템플릿 ID (숫자)
# templateArgs: title, description, url, 인원, 마감일, 카테고리, 상태, 작성자 (템플릿 사용자 인자와 동일하게)
# https://developers.kakao.com/docs/latest/ko/kakaotalk-share/js-link
VITE_KAKAO_SHARE_TEMPLATE_ID=130396

# 공유 링크 베이스 URL (권장) - 카카오톡에서 링크 클릭 시 이동할 프로덕션 주소
# 미설정 시 현재 접속 중인 도메인 사용. 배포 도메인이 다르면 여기 지정 (예: https://mojip.vercel.app)
VITE_APP_URL=
VITE_GOOGLE_MAPS_API_KEY=
